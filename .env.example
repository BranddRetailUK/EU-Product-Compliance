# Shopify OAuth / Admin API
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
APP_URL=
HOST=
SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_markets
SHOPIFY_API_VERSION=2026-04

# Local server
NODE_ENV=development
PORT=3000

# Persistence
DATABASE_URL=
PGSSLMODE=

# App security
SESSION_SECRET=

# Optional AI-assisted product/customs classification
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_PRODUCT_FIXES_ENABLED=false

# Optional automatic fix defaults
DEFAULT_PRODUCT_VENDOR=
DEFAULT_PRODUCT_TYPE=
DEFAULT_COUNTRY_OF_ORIGIN=
FREE_FIX_PRODUCT_LIMIT=10
DEV_BYPASS_BILLING_GATES=false

# Optional Shopify managed billing plan identifiers
SHOPIFY_BILLING_PLAN_FREE=
SHOPIFY_BILLING_PLAN_PRO=
