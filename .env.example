# Shopify OAuth / Admin API
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
APP_URL=
HOST=
SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_markets
SHOPIFY_API_VERSION=2026-04

# Local server
NODE_ENV=development
PORT=3000

# Persistence
DATABASE_URL=
PGSSLMODE=

# App security
SESSION_SECRET=

# Optional AI-assisted product/customs classification
OPENAI_API_KEY=

# Optional Shopify managed billing plan identifiers
SHOPIFY_BILLING_PLAN_FREE=
SHOPIFY_BILLING_PLAN_PRO=
